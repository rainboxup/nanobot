# Example environment file for `compose.yml` (closed beta / SaaS web).
#
# Copy to `.env` and fill in required secrets before running:
#   docker compose -f compose.yml up -d --build
#

# Exposed host port (container listens on 18790).
# 8317 is often used by other local services; use a different port by default.
NANOBOT_PORT=8318

# Persisted data directory on the host/server.
NANOBOT_DATA_DIR=/opt/nanobot/data

# Required: bootstrap owner password for web login (username defaults to "admin").
NANOBOT_ADMIN_PASSWORD=change-me

# Required: stable JWT signing secret (must be >= 32 characters).
# Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
NANOBOT_JWT_SECRET=replace-with-a-long-random-secret

# Closed beta gates login unless allowlisted or invited.
NANOBOT_WEB_CLOSED_BETA=1
NANOBOT_WEB_ALLOWED_USERS=admin

# Optional hardening/ops knobs.
TZ=UTC
NANOBOT_PROFILE=small
NANOBOT_WEB_AUDIT_ENABLED=1
# Refresh-cookie security policy (recommended defaults for production).
# Use HTTPS in production when Secure=1.
NANOBOT_WEB_REFRESH_COOKIE_NAME=nanobot_refresh_token
NANOBOT_WEB_REFRESH_COOKIE_SECURE=1
NANOBOT_WEB_REFRESH_COOKIE_SAMESITE=lax
NANOBOT_WEB_REFRESH_COOKIE_PATH=/api/auth
# Refresh token source strategy:
#   cookie_only | body_only | hybrid_prefer_cookie | hybrid_prefer_body
NANOBOT_WEB_REFRESH_TOKEN_SOURCE_POLICY=hybrid_prefer_cookie
# Require same-origin checks for body-based refresh tokens (recommended).
NANOBOT_WEB_REFRESH_BODY_REQUIRE_SAME_ORIGIN=1
# Reverse-proxy trust boundary (comma-separated CIDRs/IPs). Only trusted sources may
# contribute Forwarded/X-Forwarded-* origins for refresh same-origin checks.
# Example: 127.0.0.1/32,10.0.0.0/16
NANOBOT_WEB_TRUSTED_PROXY_CIDRS=
# Optional explicit browser origins allowed for refresh same-origin checks (comma-separated origins).
# Useful for cross-site frontend/API deployments and reverse-proxy setups where the
# external browser origin differs from the backend's internal base URL/host.
# Example: https://app.example.com,https://admin.example.com
NANOBOT_WEB_REFRESH_ALLOWED_ORIGINS=
# Browser CORS allowlist for API calls (comma-separated origins).
# Required when frontend and API are on different origins.
# Example: https://app.example.com,https://admin.example.com
NANOBOT_WEB_CORS_ORIGINS=
# Legacy compatibility only. Keep 0 unless you must support old WS clients that pass token in query.
# Preferred WS auth transport is subprotocol/cookie, not URL query.
NANOBOT_WEB_WS_ALLOW_QUERY_TOKEN=0
# Uvicorn WebSocket backend: prefer wsproto for better compatibility with modern websockets libs.
# Options: auto | websockets | wsproto | none
NANOBOT_WEB_UVICORN_WS_BACKEND=wsproto

# Queue/worker sizing (multi-tenant gateway).
NANOBOT_TRAFFIC__INBOUND_QUEUE_SIZE=50
NANOBOT_TRAFFIC__OUTBOUND_QUEUE_SIZE=50
NANOBOT_TRAFFIC__TENANT_BURST_LIMIT=5
NANOBOT_TRAFFIC__WORKER_CONCURRENCY=2
# Max cached tenant session managers for Web chat (LRU eviction).
NANOBOT_TRAFFIC__WEB_TENANT_SESSION_MANAGER_MAX_ENTRIES=64

# Safer SaaS defaults for exec tool:
# - keep exec disabled unless you explicitly need shell access;
# - when enabling, prefer docker mode over host mode.
NANOBOT_TOOLS__EXEC__ENABLED=0
NANOBOT_TOOLS__EXEC__MODE=docker

# Resource limits (compose.yml reads these).
NANOBOT_MEM_LIMIT=1024m
NANOBOT_CPUS=1.0
