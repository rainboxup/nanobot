# Example environment file for `compose.yml` (closed beta / SaaS web).
#
# Copy to `.env` and fill in required secrets before running:
#   docker compose -f compose.yml up -d --build
#

# Exposed host port (container listens on 18790).
NANOBOT_PORT=8317

# Persisted data directory on the host/server.
NANOBOT_DATA_DIR=/opt/nanobot/data

# Required: bootstrap owner password for web login (username defaults to "admin").
NANOBOT_ADMIN_PASSWORD=change-me

# Required: stable JWT signing secret (>= 32 bytes recommended).
# Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
NANOBOT_JWT_SECRET=replace-with-a-long-random-secret

# Closed beta gates login unless allowlisted or invited.
NANOBOT_WEB_CLOSED_BETA=1
NANOBOT_WEB_ALLOWED_USERS=admin

# Optional hardening/ops knobs.
TZ=UTC
NANOBOT_PROFILE=small
NANOBOT_WEB_AUDIT_ENABLED=1

# Queue/worker sizing (multi-tenant gateway).
NANOBOT_TRAFFIC__INBOUND_QUEUE_SIZE=50
NANOBOT_TRAFFIC__OUTBOUND_QUEUE_SIZE=50
NANOBOT_TRAFFIC__TENANT_BURST_LIMIT=5
NANOBOT_TRAFFIC__WORKER_CONCURRENCY=2

# Exec tool defaults: keep host mode unless you mount docker.sock + docker CLI.
NANOBOT_TOOLS__EXEC__MODE=host

# Resource limits (compose.yml reads these).
NANOBOT_MEM_LIMIT=1024m
NANOBOT_CPUS=1.0

